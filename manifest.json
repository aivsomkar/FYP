{
  "manifest_version": 3,
  "name": "FYP - Free YouTube Premium",
  "version": "1.0",
  "description": "Automatically skips and removes ads on YouTube and YouTube Music",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.music.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [{
    "matches": [
      "*://*.youtube.com/*",
      "*://*.music.youtube.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_idle"
  }]
}
